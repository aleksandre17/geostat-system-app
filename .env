src/
    Layout/         ← AppLayout, Login, menu/, SettingsLoader
    api/            ← httpClient, queryClient
    auth/           ← core/ → authentication/ → authorization/ → hooks/ → guards/
    components/     ← shared: FormSection, RecordNotFound, IconLoader
    config/         ← api.config, pages.config, upload.config, websocket.config
    context/        ← SettingsContext
    features/       ← dashboard/, users/, roles/, permissions/, cms/, upload/
    providers/      ← dataProviders
    services/       ← WebSocketService, SettingsManager, iconManager
    themes/         ← theme definitions
    types/          ← treeCategories + types.ts
    utils/          ← helpers/formatters
